---
import { basics } from "@cv"
import { getLangFromAstro } from "@/utils/i18n"

const currentLang = getLangFromAstro(Astro)
const { profiles } = basics

const SOCIAL_ICONS: Record<string, string> = {
  GitHub: `<svg
  width="16"
  height="16"
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
  style="margin-right: 8px"
  ><path
    fill="currentColor"
    d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
  ></path></svg
>`,
  LinkedIn: `<svg
  height="16"
  width="16"
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
  style="margin-right: 8px"
  ><title>LinkedIn</title><path
    fill="currentColor"
    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
  ></path></svg
>`,
  CV: `<svg
  width="16"
  height="16"
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
  style="margin-right: 8px"
  ><title>CV</title><path
    fill="currentColor"
    d="M2 1h20v22H2V1zm18 20V3H4v16h14zm-9-2h6v-2h-6v2zm0-4h6v-2h-6v2zm0-4h6V7h-6v2zm0-4h6V3h-6v2z"
  ></path></svg
>
`,
}

const profilesInfo = profiles.map(({ network, url }) => {
  const icon = SOCIAL_ICONS[network]
  const firstLetter = network[0].toUpperCase()

  return {
    id: network,
    section: "Social",
    title: `Visit ${network}`,
    url,
    icon,
    hotkey: `ctrl+${firstLetter}`,
  }
})
---

<footer class="no-print keyboard-footer" data-i18n="keyboard.footer" set:html={currentLang === 'es' ? 'Presiona <kbd id="keyboard-key"></kbd> + <kbd>K</kbd> para abrir el menú de comandos.' : 'Press <kbd id="keyboard-key"></kbd> + <kbd>K</kbd> to open the command menu.'}>
</footer>

<ninja-keys
  data-info={JSON.stringify(profilesInfo)}
  data-icons={JSON.stringify(SOCIAL_ICONS)}
  data-profiles={JSON.stringify(profiles)}
  hideBreadcrumbs>
</ninja-keys>

<script>
  import "ninja-keys"

  const footerTexts: Record<string, string> = {
    en: 'Press <kbd id="keyboard-key"></kbd> + <kbd>K</kbd> to open the command menu.',
    es: 'Presiona <kbd id="keyboard-key"></kbd> + <kbd>K</kbd> para abrir el menú de comandos.'
  }

  const placeholders: Record<string, string> = {
    en: 'Type a command or search...',
    es: 'Escribe un comando o busca...'
  }

  const ninjaFooterTexts: Record<string, { select: string; navigate: string; close: string; back: string }> = {
    en: { select: 'to select', navigate: 'to navigate', close: 'to close', back: 'move to parent' },
    es: { select: 'para seleccionar', navigate: 'para navegar', close: 'para cerrar', back: 'volver al padre' }
  }

  const ninjaLabels: Record<string, { visit: string; social: string }> = {
    en: { visit: 'Visit', social: 'Social' },
    es: { visit: 'Visitar', social: 'Social' }
  }

  function updateNinjaDarkMode() {
    const ninja = document.querySelector("ninja-keys")
    if (!ninja) return
    
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark'
    if (isDark) {
      ninja.classList.add('dark')
    } else {
      ninja.classList.remove('dark')
    }
  }

  function updateNinjaLanguage() {
    const lang = document.documentElement.getAttribute('lang') || 'es'
    const ninja = document.querySelector("ninja-keys") as any
    if (!ninja) return

    ninja.placeholder = placeholders[lang] || placeholders.en

    const labels = ninjaLabels[lang] || ninjaLabels.en
    const icons = JSON.parse(ninja.getAttribute("data-icons") || "{}")
    const profilesData = JSON.parse(ninja.getAttribute("data-profiles") || "[]")
    const networks = ['LinkedIn', 'GitHub', 'CV']
    
    const updatedData = networks.map((network) => {
      const firstLetter = network[0].toUpperCase()
      const profile = profilesData.find((p: any) => p.network === network)
      return {
        id: network,
        section: labels.social,
        title: `${labels.visit} ${network}`,
        url: profile?.url || '#',
        icon: icons[network],
        hotkey: `ctrl+${firstLetter}`,
        handler: () => {
          window.open(profile?.url, '_blank')
        }
      }
    })
    ninja.data = updatedData

    const footerEl = ninja.shadowRoot?.querySelector('.modal-footer')
    if (footerEl) {
      const texts = ninjaFooterTexts[lang] || ninjaFooterTexts.en
      const helps = footerEl.querySelectorAll('.help')
      if (helps[0]) helps[0].innerHTML = helps[0].innerHTML.replace(/to select|para seleccionar/, texts.select)
      if (helps[1]) helps[1].innerHTML = helps[1].innerHTML.replace(/to navigate|para navegar/, texts.navigate)
      if (helps[2]) helps[2].innerHTML = helps[2].innerHTML.replace(/to close|para cerrar/, texts.close)
      if (helps[3]) helps[3].style.display = 'none'
    }
  }

  function updateKeyboardLanguage() {
    const lang = document.documentElement.getAttribute('lang') || 'es'
    const footerEl = document.querySelector('[data-i18n="keyboard.footer"]') as HTMLElement
    if (footerEl) {
      const keyboardKey = document.getElementById('keyboard-key')
      const keyText = keyboardKey?.textContent || 'Ctrl'
      footerEl.innerHTML = footerTexts[lang] || footerTexts.en
      const newKey = document.getElementById('keyboard-key')
      if (newKey) newKey.textContent = keyText
    }
  }

  const ninja = document.querySelector("ninja-keys")

  if (ninja != null) {
    const info = ninja.getAttribute("data-info") ?? "[]"
    const parsedInfo = JSON.parse(info)

    const data = parsedInfo.map((item: any) => {
      return {
        ...item,
        handler: () => {
          window.open(item.url, "_blank")
        },
      }
    })

    ninja.data = [
      ...data,
    ]
  }

  function getOS() {
    const userAgent = window.navigator.userAgent;
    if (userAgent.includes("Mac")) {
      return "Mac";
    } else if (userAgent.includes("Win")) {
      return "Windows";
    } else if (userAgent.includes("Linux")) {
      return "Linux";
    }
    return "Unknown";
  }

  function isMobile() {
    return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
  }

  document.addEventListener("DOMContentLoaded", () => {
    const keyboardKey = document.getElementById('keyboard-key');
    if (keyboardKey) {
      keyboardKey.textContent = getOS() === "Mac" ? 'Cmd' : 'Ctrl';
    }

    if (isMobile()) {
      const footer = document.querySelector('.keyboard-footer') as HTMLElement;
      if (footer) footer.style.display = 'none';
    }

    updateNinjaDarkMode()
    updateNinjaLanguage()
    updateKeyboardLanguage()
  });

  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'lang' || mutation.attributeName === 'data-theme') {
        updateNinjaDarkMode()
        updateNinjaLanguage()
        updateKeyboardLanguage()
      }
    })
  })
  
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['lang', 'data-theme'] })
</script>

<style>
  @media print {
    ninja-keys {
      display: none !important;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  footer {
    background: var(--color-background);
    border-top: 1px solid var(--color-border);
    position: fixed;
    bottom: 0px;
    width: 100%;
    padding-block: 8px;
    text-align: center;
    font-size: 0.85rem;

    view-timeline-name: --revealing;
    view-timeline-axis: block;

    animation: linear 0.3s fadeIn;
    animation-timeline: --revealing;
    animation-range: entry 100% cover 10%;
  }

  kbd {
    background: var(--color-border);
    border-radius: 4px;
    padding: 2px 4px;
    font-size: 12px;
  }

  ninja-keys {
    --ninja-width: 640px;
    --ninja-backdrop-filter: blur(4px);
    --ninja-overflow-background: rgba(0, 0, 0, 0.6);
    --ninja-text-color: var(--color-primary);
    --ninja-modal-background: var(--color-surface);
    --ninja-modal-shadow: 0 16px 70px rgba(0, 0, 0, 0.4);
    --ninja-secondary-background-color: var(--color-border);
    --ninja-secondary-text-color: var(--color-text);
    --ninja-selected-background: var(--color-border-dark);
    --ninja-selected-text-color: var(--color-primary);
    --ninja-group-text-color: var(--color-tertiary);
    --ninja-footer-background: var(--color-surface);
    --ninja-icon-color: var(--color-text);
    --ninja-separate-border: 1px solid var(--color-border);
    --ninja-placeholder-color: var(--color-text);
    --ninja-accent-color: var(--color-accent);
  }

  ninja-keys.dark {
    --ninja-overflow-background: rgba(0, 0, 0, 0.7);
    --ninja-modal-background: #1a1a1a;
    --ninja-text-color: #e0e0e0;
    --ninja-secondary-background-color: #333;
    --ninja-secondary-text-color: #999;
    --ninja-selected-background: #333;
    --ninja-selected-text-color: #fff;
    --ninja-footer-background: #111;
    --ninja-icon-color: #999;
    --ninja-separate-border: 1px solid #333;
    --ninja-placeholder-color: #777;
  }

  @media (width <= 700px) {
    footer {
      display: none;
    }
  }
</style>