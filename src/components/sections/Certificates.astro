---
import Section from "../Section.astro"

import { certificates } from "@cv"
import { month, shortMonth } from "@/utils/utils.ts"
import { getLangFromAstro } from "@/utils/i18n"

const currentLang = getLangFromAstro(Astro)

const firstThreeCertificates = certificates.slice(0, 3)
const extraCertificates = certificates.slice(3)
---

<Section title="Certificates">
  <ul>
    {
      firstThreeCertificates.map(({ name, date, issuer, url }, index) => {
        return (
          <li>
            <article>
              <header>
                <div>
                  <h4>
                    <a class="link-certificate" href={url} target="_blank" data-i18n={`certificates[${index}].name`}>{name[currentLang as keyof typeof name] || name.en}</a>
                  </h4>
                </div>
                <time data-date={date}>
                  <span class="date-desktop" data-i18n={`certificates[${index}].date`}>{month(date, currentLang)}</span>
                  <span class="date-mobile" data-i18n={`certificates[${index}].dateShort`}>{shortMonth(date, currentLang)}</span>
                </time>
              </header>
              <footer>
                <p>{issuer}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>

  <ul id="extra-certificates" class="hidden">
    {
      extraCertificates.map(({ name, date, issuer, url }, index) => {
        const realIndex = index + 3;
        return (
          <li>
            <article>
              <header>
                <div>
                  <h4>
                    <a class="link-certificate" href={url} target="_blank" data-i18n={`certificates[${realIndex}].name`}>{name[currentLang as keyof typeof name] || name.en}</a>
                  </h4>
                </div>
                <time data-date={date}>
                  <span class="date-desktop" data-i18n={`certificates[${realIndex}].date`}>{month(date, currentLang)}</span>
                  <span class="date-mobile" data-i18n={`certificates[${realIndex}].dateShort`}>{shortMonth(date, currentLang)}</span>
                </time>
              </header>
              <footer>
                <p>{issuer}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>

  <button id="button-more">
    <p class="more" data-i18n="certificates.more">+{extraCertificates.length} {currentLang === 'es' ? 'más' : 'more'}</p>
  </button>


  <script>
    import { certificates } from "@cv"
    import { month, shortMonth } from "@/utils/utils.ts"
    
    const moreTexts: Record<string, { more: string; less: string }> = {
      en: { more: 'more', less: 'less' },
      es: { more: 'más', less: 'menos' }
    }

    let isExpanded = false

    function updateCertificatesLanguage() {
      const lang = document.documentElement.getAttribute('lang') || 'es'
      
      certificates.forEach((cert, index) => {
        const nameEl = document.querySelector(`[data-i18n="certificates[${index}].name"]`)
        if (nameEl && cert.name) {
          nameEl.textContent = cert.name[lang as keyof typeof cert.name] || cert.name.en
        }

        const dateEl = document.querySelector(`[data-i18n="certificates[${index}].date"]`) as HTMLSpanElement
        const dateShortEl = document.querySelector(`[data-i18n="certificates[${index}].dateShort"]`) as HTMLSpanElement
        
        const parentTime = (dateEl || dateShortEl)?.parentElement
        if (parentTime) {
          const date = parentTime.dataset.date || ''
          if (dateEl) dateEl.textContent = month(date, lang)
          if (dateShortEl) dateShortEl.textContent = shortMonth(date, lang)
        }
      })

      const moreEl = document.querySelector('[data-i18n="certificates.more"]')
      if (moreEl) {
        const extraCerts = document.getElementById('extra-certificates')
        const count = extraCerts ? extraCerts.children.length : 0
        const texts = moreTexts[lang] || moreTexts.en
        moreEl.textContent = isExpanded
          ? `- ${texts.less}`
          : `+${count} ${texts.more}`
      }
    }

    updateCertificatesLanguage()
    
    const buttonMore = document.getElementById('button-more');
    const extraCertificates = document.getElementById('extra-certificates') as HTMLElement;
    const moreEl = document.querySelector('[data-i18n="certificates.more"]') as HTMLElement;

    if (buttonMore && extraCertificates && moreEl) {
      buttonMore.addEventListener('click', () => {
        moreEl.style.transition = 'opacity 0.15s ease-in-out';
        moreEl.style.opacity = '0';

        if (isExpanded) {
          extraCertificates.style.transition = 'opacity 0.15s ease-in-out';
          extraCertificates.style.opacity = '0';
          
          setTimeout(() => {
            extraCertificates.classList.add('hidden');
            isExpanded = false;
            
            const lang = document.documentElement.getAttribute('lang') || 'es';
            const texts = moreTexts[lang] || moreTexts.en;
            moreEl.textContent = `+${extraCertificates.children.length} ${texts.more}`;
            moreEl.style.opacity = '1';
          }, 150);
        } else {
          setTimeout(() => {
            extraCertificates.classList.remove('hidden');
            isExpanded = true;
            
            extraCertificates.style.opacity = '0';
            extraCertificates.style.transition = 'opacity 0.15s ease-in-out';
            extraCertificates.offsetHeight;
            
            const lang = document.documentElement.getAttribute('lang') || 'es';
            const texts = moreTexts[lang] || moreTexts.en;
            moreEl.textContent = `- ${texts.less}`;
            
            moreEl.style.opacity = '1';
            extraCertificates.style.opacity = '1';
          }, 150);
        }
      });
    }
    
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'lang') {
          updateCertificatesLanguage()
        }
      })
    })
    
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] })
  </script>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  button {
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-text);
    font-weight: 500;
  }

  article h3 {
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: var(--spacing-xs);
  }

  article h4, .link-certificate {
    color: var(--color-secondary);
    font-weight: 400;
  }

  .link-education:hover {
    text-decoration: underline;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--spacing-xs);
  }

  time {
    color: var(--color-text);
    font-size: var(--font-size-lg);
    text-align: end;
    white-space: nowrap;
    margin-left: 1rem;
  }

  .date-mobile {
    display: none;
  }

  @media (width <= 700px) {
    .date-desktop {
      display: none;
    }
    .date-mobile {
      display: inline;
    }
  }

  .hidden {
    display: none;
  }
</style>