---
import Section from "../Section.astro"

import { education } from "@cv"
import { monthYear } from "@/utils/utils.ts"
import { getLangFromAstro } from "@/utils/i18n"

const currentLang = getLangFromAstro(Astro)
---

<Section title="Education">
  <ul>
    {
      education.map(
        ({ institution, url, area, studyType, startDate, endDate }, index) => {
          return (
            <li>
              <article>
                <header>
                  <div>
                    <h3>
                      <a href={url} target="_blank">{institution}</a>
                    </h3>
                    <h4 data-i18n={`education[${index}].area`}>{area[currentLang as keyof typeof area] || area.en}</h4>
                  </div>
                  <time data-i18n={`education[${index}].date`} data-start={startDate} data-end={endDate || ''}>{monthYear(startDate, endDate, currentLang)}</time>
                </header>
                <footer>
                  <p data-i18n={`education[${index}].studyType`}>{studyType[currentLang as keyof typeof studyType] || studyType.en}</p>
                </footer>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>

<script>
  import { education } from "@cv"
  import { monthYear } from "@/utils/utils.ts"
  
  function updateEducationLanguage() {
    const lang = document.documentElement.getAttribute('lang') || 'es'
    
    education.forEach((item, index) => {
      const areaEl = document.querySelector(`[data-i18n="education[${index}].area"]`)
      if (areaEl && item.area) {
        areaEl.textContent = item.area[lang as keyof typeof item.area] || item.area.en
      }
      
      const studyTypeEl = document.querySelector(`[data-i18n="education[${index}].studyType"]`)
      if (studyTypeEl && item.studyType) {
        studyTypeEl.textContent = item.studyType[lang as keyof typeof item.studyType] || item.studyType.en
      }

      const dateEl = document.querySelector(`[data-i18n="education[${index}].date"]`) as HTMLTimeElement
      if (dateEl) {
        const startDate = dateEl.dataset.start || ''
        const endDate = dateEl.dataset.end || ''
        dateEl.textContent = monthYear(startDate, endDate || null, lang)
      }
    })
  }

  updateEducationLanguage()
  
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'lang') {
        updateEducationLanguage()
      }
    })
  })
  
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] })
</script>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  article h3 {
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: var(--spacing-xs);
  }

  article h3 a {
    color: var(--color-primary);
  }

  article h3 a:hover {
    text-decoration: underline;
  }

  article h4 {
    color: var(--color-secondary);
    font-weight: 400;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--spacing-xs);
  }

  time {
    color: var(--color-text);
    font-size: var(--font-size-lg);
    text-align: end;
  }
</style>