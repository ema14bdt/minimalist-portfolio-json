---
import Section from "../Section.astro"

import { skills } from "@cv"
import { getLangFromAstro } from "@/utils/i18n"

const currentLang = getLangFromAstro(Astro)

interface Skill {
  name: string
  level: { en: string; es: string }
  category: { en: string; es: string }
  keywords: { en: string[]; es: string[] }
}

const skillsByCategory = skills.reduce((acc, skill) => {
  const category = (skill as Skill).category || { en: "Other", es: "Otro" }
  const categoryKey = category.en
  if (!acc[categoryKey]) acc[categoryKey] = { category, skills: [] }
  acc[categoryKey].skills.push(skill)
  acc[categoryKey].skills.sort((a: any, b: any) => a.name.localeCompare(b.name))
  return acc
}, {} as Record<string, { category: { en: string; es: string }; skills: any[] }>)
---

<Section title="Skills">
  {
    Object.entries(skillsByCategory).map(([key, { category }], index) => (
      <div class="skills-category">
        <h3 data-i18n={`skills.category[${index}]`}>{category[currentLang as keyof typeof category] || category.en}</h3>
        <ul>
          {skillsByCategory[key].skills.map(({ name }) => (
            <li>
              <span>{name}</span>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</Section>

<script>
  import { skills } from "@cv"
  
  interface Skill {
    name: string
    level: { en: string; es: string }
    category: { en: string; es: string }
    keywords: { en: string[]; es: string[] }
  }
  
  const skillsByCategory = skills.reduce((acc, skill) => {
    const category = (skill as Skill).category || { en: "Other", es: "Otro" }
    const categoryKey = category.en
    if (!acc[categoryKey]) acc[categoryKey] = { category, skills: [] }
    acc[categoryKey].skills.push(skill)
    return acc
  }, {} as Record<string, { category: { en: string; es: string }; skills: any[] }>)
  
  function updateSkillsLanguage() {
    const lang = document.documentElement.getAttribute('lang') || 'es'
    
    Object.values(skillsByCategory).forEach(({ category }, index) => {
      const categoryEl = document.querySelector(`[data-i18n="skills.category[${index}]"]`)
      if (categoryEl && category) {
        categoryEl.textContent = category[lang as keyof typeof category] || category.en
      }
    })
  }

  updateSkillsLanguage()
  
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'lang') {
        updateSkillsLanguage()
      }
    })
  })
  
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] })
</script>

<style>
  .skills-category {
    margin-bottom: 1.5rem;
  }

  .skills-category:last-child {
    margin-bottom: 0;
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  ul {
    display: inline-flex;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  li {
    border-radius: var(--radius-sm);
    background: var(--color-border);
    color: var(--color-tertiary);
    font-size: var(--font-size-md);
    font-weight: 500;
    padding: 0.2rem 0.6rem;
  }
</style>